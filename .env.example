# Copier ce fichier en .env et remplir les clés (ne pas committer .env)
# start_bridge.bat charge ce fichier automatiquement. Sinon : python-dotenv ou variables d'environnement.
# Les lignes avec # sont ignorées : DÉCOMMENTER la ligne de la clé que vous utilisez.

# Pour Gemini (Google) — décommenter et remplacer par votre clé :
# GEMINI_API_KEY=votre_cle_api_google

# Pour Claude (Anthropic) — décommenter si vous utilisez Anthropic :
# ANTHROPIC_API_KEY=sk-ant-...

# Modèle Gemini (optionnel). Défaut = gemini-2.5-flash. Ex. Pro : gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash

# --- Provider local (LM Studio, Ollama, etc.) : pas de clé API ---
# LOCAL_API_URL=http://localhost:1234/v1
# LOCAL_MODEL=qwen3.5-9b
